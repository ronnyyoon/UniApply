{
  "entities": {
    "CollegeStat": {
      "title": "College Admission Result",
      "description": "Admissions results statistics for a specific college, major, type, and detailType.",
      "type": "object",
      "properties": {
        "college": { "type": "string", "description": "University name" },
        "major": { "type": "string", "description": "Major / Department" },
        "type": { "type": "string", "description": "Admission type" },
        "detailType": { "type": "string", "description": "Detailed admission category" },
        "recruitCount2026": { "type": "string", "description": "Recruitment count in 2026" },
        "cut70_2026": { "type": "string", "description": "70% cut off in 2026" },
        "chuhapNo2026": { "type": "string", "description": "Chuhap (additional path number) in 2026" },
        "ratio2026": { "type": "string", "description": "Competition ratio in 2026" },
        "recruitCount2025": { "type": "string", "description": "Recruitment count in 2025" },
        "cut70_2025": { "type": "string", "description": "70% cut off in 2025" },
        "chuhapNo2025": { "type": "string", "description": "Chuhap in 2025" },
        "ratio2025": { "type": "string", "description": "Competition ratio in 2025" },
        "recruitCount2024": { "type": "string", "description": "Recruitment count in 2024" },
        "cut70_2024": { "type": "string", "description": "70% cut off in 2024" },
        "chuhapNo2024": { "type": "string", "description": "Chuhap in 2024" },
        "ratio2024": { "type": "string", "description": "Competition ratio in 2024" }
      },
      "required": ["college", "major", "type", "detailType"]
    },
    "StudentSheet": {
      "title": "Student Target College Calculation Sheet",
      "description": "Shared calculation spreadsheet rows for a student's target universities",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Student ID" },
        "rows": { "type": "array", "description": "List of target college calculation rows" },
        "updatedAt": { "type": "string", "description": "Last update timestamp" },
        "updatedBy": { "type": "string", "description": "Name of last modifier (student or teacher)" }
      },
      "required": ["studentId", "rows"]
    }
  },
  "firestore": {
    "college_stats": {
      "schema": "CollegeStat",
      "description": "Collection of university admission statistics across multiple years"
    },
    "student_sheets": {
      "schema": "StudentSheet",
      "description": "Shared calculation sheets for student target universities, accessible by both students and teachers"
    }
  }
}
